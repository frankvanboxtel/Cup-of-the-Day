{
  "name": "cup-of-the-day",
  "version": "1.0.0",
  "private": true,
  "description": "Node.js TypeScript project for Cup of the Day data.",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "npm run generate:all",
    "dev": "npm run generate:all",
    "generate": "tsx src/generate-results.ts",
    "generate:all": "npm run generate && npm run validate:results && npm run generate:aliases && npm run generate:html",
    "generate:aliases": "tsx src/generators/generate-alias-proposals.ts",
    "generate:html": "tsx src/generators/generate-html.ts",
    "validate:results": "tsx src/validation/validate-results.ts",
    "start": "npm run generate:all"
  },
  "dependencies": {
    "csv-parse": "^5.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
